{
  "name": "site-mirror",
  "version": "1.0.0",
  "description": "Mirror a website into a local offline-openable snapshot.",
  "type": "module",
  "bin": {
    "site-mirror": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "commander": "^14.0.0",
    "file-type": "^20.5.0",
    "got": "^14.4.9",
    "iconv-lite": "^0.7.0",
    "mime-types": "^3.0.1",
    "p-limit": "^7.1.0",
    "postcss": "^8.5.6",
    "postcss-value-parser": "^4.2.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
